{
  "name": "Beatles: George",
  "type": "dark",
  "colors": {
    "editor.background": "#1A1230",
    "editor.foreground": "#D8CCE8",
    "editorCursor.foreground": "#E89B2D",
    "editor.selectionBackground": "#2A1F45",
    "editor.lineHighlightBackground": "#1F1738",
    "editorLineNumber.foreground": "#4A3D66",
    "editorLineNumber.activeForeground": "#E89B2D",
    "sideBar.background": "#140E28",
    "sideBar.foreground": "#C4B8D8",
    "sideBarTitle.foreground": "#E89B2D",
    "activityBar.background": "#0F0A20",
    "activityBar.foreground": "#D8CCE8",
    "statusBar.background": "#6B3FA0",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#1A1230",
    "titleBar.activeForeground": "#D8CCE8",
    "tab.activeBackground": "#1A1230",
    "tab.inactiveBackground": "#140E28",
    "tab.activeForeground": "#FFFFFF",
    "terminal.background": "#1A1230",
    "terminal.foreground": "#D8CCE8",
    "panel.background": "#140E28",
    "input.background": "#1F1738",
    "input.foreground": "#D8CCE8",
    "input.border": "#3D3060",
    "dropdown.background": "#1F1738",
    "dropdown.foreground": "#D8CCE8"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4A3D66", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#E89B2D" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#F0B84A" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#A87FD4" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#D4883A" }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#9B6BC8" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#D8CCE8" }
    },
    {
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#F0B84A" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#A87FD4" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#E89B2D" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#7A6B99" }
    }
  ]
}
