{
  "name": "Beatles: Ringo",
  "type": "dark",
  "colors": {
    "editor.background": "#0F1E3D",
    "editor.foreground": "#E0E8D8",
    "editorCursor.foreground": "#FFD700",
    "editor.selectionBackground": "#1A3055",
    "editor.lineHighlightBackground": "#142548",
    "editorLineNumber.foreground": "#3A5580",
    "editorLineNumber.activeForeground": "#FFD700",
    "sideBar.background": "#0A1830",
    "sideBar.foreground": "#C8D8C0",
    "sideBarTitle.foreground": "#FFD700",
    "activityBar.background": "#061228",
    "activityBar.foreground": "#E0E8D8",
    "statusBar.background": "#2E8B57",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#0F1E3D",
    "titleBar.activeForeground": "#E0E8D8",
    "tab.activeBackground": "#0F1E3D",
    "tab.inactiveBackground": "#0A1830",
    "tab.activeForeground": "#FFFFFF",
    "terminal.background": "#0F1E3D",
    "terminal.foreground": "#E0E8D8",
    "panel.background": "#0A1830",
    "input.background": "#142548",
    "input.foreground": "#E0E8D8",
    "input.border": "#2A4570",
    "dropdown.background": "#142548",
    "dropdown.foreground": "#E0E8D8"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3A5580", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#7DCE82" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FFD700" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#5CB8E6" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#FFD700" }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#5DBE8A" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E0E8D8" }
    },
    {
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#FFD700" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#5CB8E6" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#7DCE82" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#5A7AA0" }
    }
  ]
}
