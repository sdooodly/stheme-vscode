{
  "name": "Beatles: John",
  "type": "dark",
  "colors": {
    "editor.background": "#0A0A0A",
    "editor.foreground": "#E8E8E8",
    "editorCursor.foreground": "#FF4500",
    "editor.selectionBackground": "#2A1A1A",
    "editor.lineHighlightBackground": "#141414",
    "editorLineNumber.foreground": "#4A4A4A",
    "editorLineNumber.activeForeground": "#FF4500",
    "sideBar.background": "#050505",
    "sideBar.foreground": "#CCCCCC",
    "sideBarTitle.foreground": "#FF4500",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#E8E8E8",
    "statusBar.background": "#8B0000",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#0A0A0A",
    "titleBar.activeForeground": "#E8E8E8",
    "tab.activeBackground": "#0A0A0A",
    "tab.inactiveBackground": "#050505",
    "tab.activeForeground": "#FFFFFF",
    "terminal.background": "#0A0A0A",
    "terminal.foreground": "#E8E8E8",
    "panel.background": "#050505",
    "input.background": "#141414",
    "input.foreground": "#E8E8E8",
    "input.border": "#333333",
    "dropdown.background": "#141414",
    "dropdown.foreground": "#E8E8E8"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#555555", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#FF6B35" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FF4500" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#E84040" }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#CC5500" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E8E8E8" }
    },
    {
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#FF4500" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#FF4500" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FF6B35" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#777777" }
    }
  ]
}
