{
  "name": "Beatles: John Lennon",
  "type": "dark",
  "colors": {
    "editor.background": "#1C1C1A",
    "editor.foreground": "#E8E8E0",
    "editorCursor.foreground": "#6B7C4E",
    "editor.selectionBackground": "#3A3A32",
    "editor.lineHighlightBackground": "#242422",
    "editorLineNumber.foreground": "#4A4A44",
    "editorLineNumber.activeForeground": "#8B9B6B",
    "sideBar.background": "#161614",
    "sideBar.foreground": "#C8C8C0",
    "sideBarTitle.foreground": "#8B9B6B",
    "activityBar.background": "#111110",
    "activityBar.foreground": "#E8E8E0",
    "statusBar.background": "#4A5535",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#1C1C1A",
    "titleBar.activeForeground": "#E8E8E0",
    "tab.activeBackground": "#1C1C1A",
    "tab.inactiveBackground": "#161614",
    "tab.activeForeground": "#FFFFFF",
    "terminal.background": "#1C1C1A",
    "terminal.foreground": "#E8E8E0",
    "panel.background": "#161614",
    "input.background": "#242422",
    "input.foreground": "#E8E8E0",
    "input.border": "#3A3A32",
    "dropdown.background": "#242422",
    "dropdown.foreground": "#E8E8E0",
    "badge.background": "#6B7C4E",
    "badge.foreground": "#FFFFFF",
    "button.background": "#6B7C4E",
    "button.foreground": "#FFFFFF",
    "list.activeSelectionBackground": "#3A3A32",
    "list.hoverBackground": "#2A2A28",
    "editorBracketMatch.background": "#3A3A3240",
    "editorBracketMatch.border": "#8B9B6B"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5A5A50", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template", "string.interpolated"],
      "settings": { "foreground": "#8B9B6B" }
    },
    {
      "name": "String escape characters",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#B8C89A" }
    },
    {
      "name": "Template literal punctuation",
      "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Numbers and constants",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": { "foreground": "#B8C89A" }
    },
    {
      "name": "Language constants (true, false, null, None, nil)",
      "scope": ["constant.language", "support.constant", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#B8C89A" }
    },
    {
      "name": "Keywords (if, else, for, while, return, etc.)",
      "scope": ["keyword", "keyword.control", "keyword.control.flow", "keyword.control.conditional", "keyword.control.loop"],
      "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" }
    },
    {
      "name": "Storage (var, let, const, function, class, def, fn, pub)",
      "scope": ["storage.type", "storage.modifier", "keyword.control.def", "keyword.control.class"],
      "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical", "keyword.operator.comparison"],
      "settings": { "foreground": "#C8C8B8" }
    },
    {
      "name": "Function definitions",
      "scope": ["entity.name.function", "meta.function entity.name.function"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call entity.name.function", "variable.function", "support.function", "meta.method-call entity.name.function", "entity.name.function.call"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "Built-in functions (print, len, range, parseInt, etc.)",
      "scope": ["support.function.builtin", "support.function.magic", "meta.function-call support.function"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "Method calls",
      "scope": ["meta.method-call", "variable.function.member"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "Classes and types",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.name.type.class"],
      "settings": { "foreground": "#6B7C4E" }
    },
    {
      "name": "Inherited class",
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#6B7C4E", "fontStyle": "italic" }
    },
    {
      "name": "Interfaces and type parameters",
      "scope": ["entity.name.type.interface", "entity.name.type.parameter", "entity.name.type.enum"],
      "settings": { "foreground": "#7A8B5A" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#E8E8E0" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": { "foreground": "#C8C8B8" }
    },
    {
      "name": "Object properties / members",
      "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key", "support.variable.property"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "Self / this / cls",
      "scope": ["variable.language", "variable.language.this", "variable.language.self", "variable.language.special"],
      "settings": { "foreground": "#FFFFFF", "fontStyle": "italic" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.definition.decorator", "meta.annotation"],
      "settings": { "foreground": "#6B7C4E" }
    },
    {
      "name": "Import / require / use",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.other.import"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Module / package names",
      "scope": ["entity.name.import", "entity.name.package", "support.module"],
      "settings": { "foreground": "#8B9B6B" }
    },
    {
      "name": "HTML/XML tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "HTML/XML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#8B9B6B" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name", "meta.property-name"],
      "settings": { "foreground": "#A8B888" }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value", "meta.property-value"],
      "settings": { "foreground": "#8B9B6B" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#6B7C4E" }
    },
    {
      "name": "Punctuation (brackets, parens, semicolons)",
      "scope": ["punctuation", "punctuation.definition", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#6A6A60" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#8B9B6B" }
    }
  ]
}
