      {
        "label": "Beatles: George Harrison (Light)",
        "uiTheme": "vs",
        "path": "./themes/george-harrison-light.json"
      },
      {
        "label": "Beatles: Ringo Starr",
        "uiTheme": "vs-dark",
        "path": "./themes/ringo-starr.json"
